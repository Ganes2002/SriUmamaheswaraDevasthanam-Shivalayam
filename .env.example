# Copy this file to .env.local and fill in your Supabase project values.
# Get these from: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Panchangam live data (optional but recommended) ──────────────────────────
# Set temple GPS coordinates so sunrise/sunset and timing are location-specific.
# Default is Vijayawada, AP (16.5062, 80.6480). Update to your temple's location.
VITE_TEMPLE_LATITUDE=16.5062
VITE_TEMPLE_LONGITUDE=80.6480

# Prokerala API credentials go in Supabase Secrets (NOT here — never in frontend).
# Set them via: supabase secrets set PROKERALA_CLIENT_ID=xxx PROKERALA_CLIENT_SECRET=xxx
# Or: Supabase Dashboard → Edge Functions → your project → Secrets
